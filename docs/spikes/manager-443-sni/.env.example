# Kopieer naar .env en vul PKI_DIR in.
#
# PKI_DIR = absoluut pad naar de test-PKI uit de open-fsc-checkout.
# Die certs zijn in open-fsc gecommit (test-materiaal); wij committen geen keys.
#   git clone https://gitlab.com/rinis-oss/fsc/open-fsc
#   PKI_DIR=/absolute/path/to/open-fsc/pki
PKI_DIR=/absolute/path/to/open-fsc/pki

# Image-tag (open-fsc release). LET OP: tags hebben een 'v'-prefix op Docker Hub.
# Houd dit gelijk aan de open-fsc-versie waarvan je de PKI gebruikt (zie README).
IMAGE_TAG=v1.43.7
