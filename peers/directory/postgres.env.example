# Env-template voor de directory-postgres-component (#723). Invoeren in ZAD Operations Manager.
# De manager-migrate-wrapper draait alleen `migrate up` (geen CREATE DATABASE), dus de database
# `fsc_directory` moet al bestaan. Het postgres:17-image maakt POSTGRES_DB aan bij eerste boot.
#
# Persistent + gebackupt (system-of-record): NIET preview-cloned/ephemeral (zie docs/zad-projecten.md).
POSTGRES_DB=fsc_directory
POSTGRES_USER=fsc
# Wachtwoord via ZAD-secret, nooit hier invullen. Moet matchen met STORAGE_POSTGRES_DSN
# in peers/directory/manager.env.example.
POSTGRES_PASSWORD=CHANGEME
